<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Busco tu Renta by Jocelyn</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            /* Paleta de Colores de Alto Standing */
            --bg-general: #f1f5f9;
            --azul-marino: #06142e;
            --fucsia-neon: #ff007f;
            --turquesa: #00f5d4;
            --blanco: #ffffff;
            --texto-principal: #1e293b;
            --texto-secundario: #64748b;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(255, 255, 255, 0.4);
            --shadow-soft: 0 10px 30px rgba(6, 20, 46, 0.05);
            --shadow-hover: 0 20px 40px rgba(6, 20, 46, 0.12);
            --transicion: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-general);
            color: var(--texto-principal);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ANIMACIONES MAESTRAS */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        /* HEADER STICKY GLASSMORPHISM */
        .header {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--glass-border);
            padding: 24px 0;
            transition: var(--transicion);
        }
        .header.scrolled {
            padding: 12px 0;
            box-shadow: var(--shadow-soft);
            background: rgba(255, 255, 255, 0.9);
        }
        .nav-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo-container {
            font-size: 24px;
            font-weight: 800;
            color: var(--azul-marino);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            letter-spacing: -0.5px;
        }
        .logo-container span {
            color: var(--fucsia-neon);
        }
        .logo-container img {
            max-height: 45px;
            width: auto;
        }
        .nav-links a {
            color: var(--azul-marino);
            text-decoration: none;
            font-weight: 600;
            margin-left: 32px;
            font-size: 15px;
            transition: var(--transicion);
        }
        .nav-links a:hover {
            color: var(--turquesa);
        }

        /* HERO SECTION (PERFIL) */
        .hero-section {
            padding: 80px 24px;
            display: flex;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background: radial-gradient(circle at top right, rgba(0, 245, 212, 0.1), transparent 40%),
                        radial-gradient(circle at bottom left, rgba(255, 0, 127, 0.05), transparent 40%);
        }
        .perfil-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 48px;
            display: flex;
            align-items: center;
            gap: 48px;
            max-width: 1000px;
            width: 100%;
            box-shadow: var(--shadow-soft);
            animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .foto-perfil {
            width: 220px;
            height: 220px;
            object-fit: cover;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(6, 20, 46, 0.1);
            border: 4px solid var(--blanco);
        }
        .info-perfil h3 {
            color: var(--azul-marino);
            font-size: 38px;
            font-weight: 800;
            margin-bottom: 8px;
            letter-spacing: -1px;
        }
        .info-perfil h4 {
            color: var(--turquesa);
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 20px;
        }
        .info-perfil p {
            color: var(--texto-secundario);
            font-size: 16px;
            line-height: 1.7;
            margin-bottom: 30px;
        }
        .btn-contacto-group {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }
        .btn-contacto {
            padding: 14px 28px;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: var(--transicion);
        }
        .btn-whatsapp {
            background-color: var(--azul-marino);
            color: var(--blanco);
        }
        .btn-whatsapp:hover {
            background-color: var(--turquesa);
            color: var(--azul-marino);
            transform: translateY(-3px);
        }
        .btn-correo {
            background-color: transparent;
            color: var(--azul-marino);
            border: 2px solid var(--azul-marino);
        }
        .btn-correo:hover {
            background-color: var(--fucsia-neon);
            color: var(--blanco);
            border-color: var(--fucsia-neon);
            transform: translateY(-3px);
        }

        /* INVENTARIO SECTION */
        .inventario-section {
            padding: 60px 24px 100px;
            max-width: 1280px;
            margin: 0 auto;
            width: 100%;
        }
        .seccion-titulo {
            text-align: center;
            color: var(--azul-marino);
            font-size: 40px;
            font-weight: 800;
            margin-bottom: 60px;
            letter-spacing: -1px;
        }
        .seccion-titulo span {
            color: var(--fucsia-neon);
        }
        .grid-propiedades {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
            gap: 40px;
        }

        /* SKELETON LOADING */
        .skeleton-card {
            background: var(--blanco);
            border-radius: 24px;
            height: 520px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            box-shadow: var(--shadow-soft);
        }
        .skeleton-box {
            background: linear-gradient(90deg, #e2e8f0 25%, #cbd5e1 50%, #e2e8f0 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: 12px;
        }
        .skeleton-img { height: 260px; border-radius: 20px; }
        .skeleton-title { height: 28px; width: 80%; }
        .skeleton-text { height: 18px; width: 100%; }
        .skeleton-text-short { height: 18px; width: 60%; }

        /* TARJETAS DE PROPIEDAD */
        .tarjeta-propiedad {
            background: var(--blanco);
            border-radius: 24px;
            box-shadow: var(--shadow-soft);
            transition: var(--transicion);
            display: flex;
            flex-direction: column;
            opacity: 0; 
            border: 1px solid rgba(226, 232, 240, 0.8);
            /* La animación se inyecta en línea vía JS */
        }
        .tarjeta-propiedad:hover {
            transform: translateY(-12px);
            box-shadow: var(--shadow-hover);
        }
        .imagen-wrapper {
            position: relative;
            height: 280px;
            overflow: hidden;
            border-radius: 24px 24px 0 0;
            background-color: #e2e8f0;
        }
        .imagen-principal {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
        }
        .tarjeta-propiedad:hover .imagen-principal {
            transform: scale(1.08);
        }
        .badge-operacion {
            position: absolute;
            top: 20px;
            left: 20px;
            background: var(--glass-bg);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            color: var(--azul-marino);
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 800;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
            z-index: 2;
        }
        .badge-operacion.venta {
            background: var(--azul-marino);
            color: var(--turquesa);
        }
        .precio-tag {
            position: absolute;
            bottom: -20px;
            right: 24px;
            background: var(--fucsia-neon);
            color: var(--blanco);
            padding: 12px 24px;
            border-radius: 20px;
            font-weight: 800;
            font-size: 22px;
            box-shadow: 0 10px 20px rgba(255, 0, 127, 0.2);
            z-index: 2;
        }
        
        .info-propiedad {
            padding: 40px 32px 32px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }
        .info-propiedad h3 {
            color: var(--azul-marino);
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 12px;
            line-height: 1.3;
        }
        .estado-tag {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--turquesa);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .estado-tag i { font-size: 8px; }
        
        .detalles-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding-bottom: 24px;
            border-bottom: 1px solid #e2e8f0;
            margin-bottom: 24px;
        }
        .detalle-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .detalle-item span:first-child {
            color: var(--texto-secundario);
            font-size: 12px;
            font-weight: 600;
        }
        .detalle-item span:last-child {
            color: var(--azul-marino);
            font-size: 15px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* CARRUSEL MINIATURAS */
        .carrusel-galeria {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding-bottom: 12px;
            margin-bottom: auto;
            scrollbar-width: none; /* Firefox */
        }
        .carrusel-galeria::-webkit-scrollbar {
            display: none; /* Chrome/Safari */
        }
        .thumb-img {
            width: 70px;
            height: 50px;
            object-fit: cover;
            border-radius: 8px;
            cursor: pointer;
            opacity: 0.6;
            transition: var(--transicion);
            border: 2px solid transparent;
            flex-shrink: 0;
        }
        .thumb-img:hover, .thumb-img.active {
            opacity: 1;
            border-color: var(--turquesa);
        }

        .btn-accion {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            background: var(--bg-general);
            color: var(--azul-marino);
            padding: 16px;
            border-radius: 16px;
            text-decoration: none;
            font-weight: 700;
            font-size: 15px;
            transition: var(--transicion);
            margin-top: 24px;
            border: 1px solid #e2e8f0;
        }
        .btn-accion:hover {
            background: var(--azul-marino);
            color: var(--blanco);
            border-color: var(--azul-marino);
        }

        /* FOOTER */
        .footer {
            background-color: var(--azul-marino);
            padding: 60px 24px 30px;
            margin-top: auto;
            text-align: center;
        }
        .redes-sociales {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
        }
        .redes-sociales a {
            color: var(--blanco);
            background: rgba(255, 255, 255, 0.05);
            width: 45px;
            height: 45px;
            display: none; /* Oculto por defecto */
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 18px;
            text-decoration: none;
            transition: var(--transicion);
        }
        .redes-sociales a.visible {
            display: flex;
        }
        .redes-sociales a:hover {
            background: var(--turquesa);
            color: var(--azul-marino);
            transform: translateY(-5px);
        }
        .footer-texto {
            color: rgba(255, 255, 255, 0.6);
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 16px;
        }
        .firma-agencia {
            color: rgba(255, 255, 255, 0.4);
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .firma-agencia span {
            color: var(--blanco);
        }
        .firma-agencia i {
            color: var(--fucsia-neon);
            font-size: 14px;
        }

        @media (max-width: 900px) {
            .perfil-card { flex-direction: column; text-align: center; padding: 40px 24px; gap: 32px; }
            .btn-contacto-group { justify-content: center; }
        }
        @media (max-width: 600px) {
            .grid-propiedades { grid-template-columns: 1fr; }
            .nav-links { display: none; }
            .seccion-titulo { font-size: 32px; }
            .info-perfil h3 { font-size: 32px; }
        }
    </style>
</head>
<body>

    <header class="header" id="main-header">
        <div class="nav-container">
            <a href="#" class="logo-container" id="logo-render">Busco tu Renta <span>by Jocelyn</span></a>
            <nav class="nav-links">
                <a href="#perfil">Sobre Mí</a>
                <a href="#inventario">Propiedades</a>
            </nav>
        </div>
    </header>

    <section id="perfil" class="hero-section">
        <div class="perfil-card" id="perfil-render">
            <div style="width:100%; text-align:center; color: var(--texto-secundario);">
                <i class="fa-solid fa-circle-notch fa-spin fa-2x"></i>
                <p style="margin-top:10px; font-weight:600;">Sincronizando Perfil...</p>
            </div>
        </div>
    </section>

    <section id="inventario" class="inventario-section">
        <h2 class="seccion-titulo">Nuestro <span>Inventario</span></h2>
        <div class="grid-propiedades" id="inventario-render">
            <div class="skeleton-card">
                <div class="skeleton-box skeleton-img"></div>
                <div class="skeleton-box skeleton-title" style="margin-top:20px;"></div>
                <div class="skeleton-box skeleton-text"></div>
                <div class="skeleton-box skeleton-text-short"></div>
            </div>
            <div class="skeleton-card">
                <div class="skeleton-box skeleton-img"></div>
                <div class="skeleton-box skeleton-title" style="margin-top:20px;"></div>
                <div class="skeleton-box skeleton-text"></div>
                <div class="skeleton-box skeleton-text-short"></div>
            </div>
            <div class="skeleton-card">
                <div class="skeleton-box skeleton-img"></div>
                <div class="skeleton-box skeleton-title" style="margin-top:20px;"></div>
                <div class="skeleton-box skeleton-text"></div>
                <div class="skeleton-box skeleton-text-short"></div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="redes-sociales">
            <a href="#" id="rs-facebook" target="_blank"><i class="fa-brands fa-facebook-f"></i></a>
            <a href="#" id="rs-instagram" target="_blank"><i class="fa-brands fa-instagram"></i></a>
            <a href="#" id="rs-youtube" target="_blank"><i class="fa-brands fa-youtube"></i></a>
        </div>
        <div class="footer-texto">© 2026 Busco tu Renta by Jocelyn.</div>
        <div class="firma-agencia">
            Desarrollado y automatizado por <span>IntegratCore</span> <i class="fa-solid fa-bolt"></i>
        </div>
    </footer>

    <script type="module">
        import { createClient } from 'https://esm.sh/@sanity/client';
        import imageUrlBuilder from 'https://esm.sh/@sanity/image-url';

        // 1. Configuración Estricta de Sanity
        const client = createClient({
            projectId: 'h9qxyeqi', 
            dataset: 'production',
            useCdn: false,
            apiVersion: '2023-05-03'
        });

        // 2. Helper de Imágenes
        const builder = (typeof imageUrlBuilder === 'function') ? imageUrlBuilder(client) : imageUrlBuilder.default(client);
        function urlFor(source) { 
            return builder.image(source); 
        }

        // 3. UI Interactions: Header Sticky
        window.addEventListener('scroll', () => {
            const header = document.getElementById('main-header');
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });

        // 4. Lógica Funcional: Carrusel Interactivo
        // Se declara en el scope global para ser accesible desde el HTML generado dinámicamente
        window.cambiarImagen = function(imgElement, nuevaUrl) {
            const tarjeta = imgElement.closest('.tarjeta-propiedad');
            const mainImg = tarjeta.querySelector('.imagen-principal');
            
            // Transición suave
            mainImg.style.opacity = '0.4';
            setTimeout(() => {
                mainImg.src = nuevaUrl;
                mainImg.style.opacity = '1';
            }, 200);

            // Actualizar estado activo en miniaturas
            const miniaturas = tarjeta.querySelectorAll('.thumb-img');
            miniaturas.forEach(min => min.classList.remove('active'));
            imgElement.classList.add('active');
        };

        // 5. Motor Principal de Extracción de Datos
        async function cargarDatos() {
            try {
                // Peticiones concurrentes para mayor velocidad
                const [ajustes, perfil, propiedades] = await Promise.all([
                    client.fetch('*[_type == "ajustes"][0]'),
                    client.fetch('*[_type == "perfil"][0]'),
                    client.fetch('*[_type == "propiedad"]')
                ]);

                /* --- RENDER AJUSTES --- */
                if (ajustes) {
                    if (ajustes.logo && ajustes.logo.asset) {
                        document.getElementById('logo-render').innerHTML = `<img src="${urlFor(ajustes.logo).height(80).url()}" alt="Logo Jocelyn">`;
                    }
                    if (ajustes.redesSociales) {
                        const fb = document.getElementById('rs-facebook');
                        const ig = document.getElementById('rs-instagram');
                        const yt = document.getElementById('rs-youtube');
                        
                        if (ajustes.redesSociales.facebook) { fb.href = ajustes.redesSociales.facebook; fb.classList.add('visible'); }
                        if (ajustes.redesSociales.instagram) { ig.href = ajustes.redesSociales.instagram; ig.classList.add('visible'); }
                        if (ajustes.redesSociales.youtube) { yt.href = ajustes.redesSociales.youtube; yt.classList.add('visible'); }
                    }
                }

                /* --- RENDER PERFIL --- */
                const perfilContenedor = document.getElementById('perfil-render');
                if (perfil) {
                    // Validar imagen
                    const fotoHtml = (perfil.fotoPerfil && perfil.fotoPerfil.asset) 
                        ? `<img src="${urlFor(perfil.fotoPerfil).width(400).url()}" alt="Agente" class="foto-perfil">` 
                        : '';
                    
                    // Validar contactos
                    const btnWs = perfil.contacto?.telefono 
                        ? `<a href="https://wa.me/${perfil.contacto.telefono.replace(/\D/g,'')}" target="_blank" class="btn-contacto btn-whatsapp"><i class="fa-brands fa-whatsapp"></i> Chatear Ahora</a>` 
                        : '';
                    const btnCorreo = perfil.contacto?.correo 
                        ? `<a href="mailto:${perfil.contacto.correo}" class="btn-contacto btn-correo"><i class="fa-regular fa-envelope"></i> Enviar Correo</a>` 
                        : '';

                    perfilContenedor.innerHTML = `
                        ${fotoHtml}
                        <div class="info-perfil">
                            <h3>${perfil.nombre || 'Agente Inmobiliario'}</h3>
                            <h4>${perfil.tituloPro || 'Especialista en Bienes Raíces'}</h4>
                            <p>${perfil.descripcion || 'Conectando personas con sus espacios ideales.'}</p>
                            <div class="btn-contacto-group">
                                ${btnWs}
                                ${btnCorreo}
                            </div>
                        </div>
                    `;
                } else {
                    perfilContenedor.innerHTML = `<p>No se encontraron datos de perfil.</p>`;
                }

                /* --- RENDER PROPIEDADES --- */
                const invContenedor = document.getElementById('inventario-render');
                invContenedor.innerHTML = ''; // Limpiar esqueletos

                if (!propiedades || propiedades.length === 0) {
                    invContenedor.innerHTML = `<p style="grid-column:1/-1; text-align:center; padding: 40px; font-weight:600; color:var(--texto-secundario);">No hay propiedades publicadas en este momento.</p>`;
                    return;
                }

                propiedades.forEach((prop, index) => {
                    // Regla de Seguridad: Extraer URL de Portada válida
                    const portUrlFull = (prop.imagenPrincipal && prop.imagenPrincipal.asset) ? urlFor(prop.imagenPrincipal).width(1000).url() : '';
                    const imgPortada = portUrlFull ? `<img src="${portUrlFull}" class="imagen-principal" alt="Propiedad">` : `<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#94a3b8;font-weight:600;">Sin Imagen</div>`;

                    // Lógica del Carrusel Interactivo
                    let htmlGaleria = '';
                    if (prop.galeria && Array.isArray(prop.galeria)) {
                        // Regla de Seguridad: Filtrar nulos
                        const fotosValidas = prop.galeria.filter(f => f && f.asset);
                        if (fotosValidas.length > 0) {
                            htmlGaleria = `<div class="carrusel-galeria">`;
                            
                            // Agregamos la portada original como primera miniatura si existe
                            if (portUrlFull) {
                                htmlGaleria += `<img src="${urlFor(prop.imagenPrincipal).width(150).url()}" class="thumb-img active" onclick="window.cambiarImagen(this, '${portUrlFull}')" alt="Portada">`;
                            }

                            // Agregamos el resto de la galería
                            fotosValidas.forEach((foto) => {
                                const urlThumb = urlFor(foto).width(150).url();
                                const urlFull = urlFor(foto).width(1000).url();
                                htmlGaleria += `<img src="${urlThumb}" class="thumb-img" onclick="window.cambiarImagen(this, '${urlFull}')" alt="Vista">`;
                            });
                            htmlGaleria += `</div>`;
                        }
                    }

                    // Etiquetas y Detalles
                    const esVenta = prop.operacion === 'Venta';
                    const claseOperacion = esVenta ? 'venta' : 'alquiler';
                    const precioFmt = prop.precio ? prop.precio.toLocaleString('en-US') : '0';
                    const enlace = prop.linkDePago ? prop.linkDePago : '#';
                    
                    // Inyectar HTML de la tarjeta con Animation Delay Dinámico
                    const animDelay = (index * 0.15).toFixed(2);

                    invContenedor.innerHTML += `
                        <div class="tarjeta-propiedad" style="animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: ${animDelay}s;">
                            <div class="imagen-wrapper">
                                <div class="badge-operacion ${claseOperacion}">${prop.operacion || 'Alquiler'}</div>
                                ${imgPortada}
                                <div class="precio-tag">$${precioFmt}</div>
                            </div>
                            
                            <div class="info-propiedad">
                                <h3>${prop.titulo || 'Propiedad sin título'}</h3>
                                <div class="estado-tag"><i class="fa-solid fa-circle"></i> ${prop.estado || 'Disponible'}</div>
                                
                                <div class="detalles-grid">
                                    <div class="detalle-item">
                                        <span>Habitaciones</span>
                                        <span><i class="fa-solid fa-bed" style="color:var(--turquesa); font-size:12px;"></i> ${prop.caracteristicas?.habitaciones || 0}</span>
                                    </div>
                                    <div class="detalle-item">
                                        <span>Baños</span>
                                        <span><i class="fa-solid fa-bath" style="color:var(--turquesa); font-size:12px;"></i> ${prop.caracteristicas?.banos || 0}</span>
                                    </div>
                                    <div class="detalle-item">
                                        <span>Metraje</span>
                                        <span><i class="fa-solid fa-ruler-combined" style="color:var(--turquesa); font-size:12px;"></i> ${prop.caracteristicas?.metros || 0} m²</span>
                                    </div>
                                </div>
                                
                                ${htmlGaleria}
                                
                                <a href="${enlace}" target="_blank" class="btn-accion">
                                    Contactar Asesor <i class="fa-solid fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    `;
                });

            } catch (error) {
                console.error("Error cargando datos de Sanity:", error);
                document.getElementById('inventario-render').innerHTML = `
                    <div style="grid-column:1/-1; background:#fee2e2; border:1px solid #f87171; color:#b91c1c; padding: 24px; border-radius:16px; text-align:center;">
                        <i class="fa-solid fa-triangle-exclamation" style="font-size:24px; margin-bottom:10px;"></i>
                        <p style="font-weight:700;">Error de conexión con la Base de Datos.</p>
                        <p style="font-size:14px; margin-top:8px;">${error.message}</p>
                    </div>
                `;
            }
        }

        // 6. Iniciar Aplicación
        cargarDatos();
    </script>
</body>
</html>
